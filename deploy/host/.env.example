# Ouroboros Desktop home-host environment template

# Telegram bridge (optional; can be configured later in Dashboard)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Server bind/security
OUROBOROS_SERVER_HOST=127.0.0.1
OUROBOROS_SERVER_PORT=8765
OUROBOROS_NETWORK_PASSWORD=

# Canonical app paths (home-host profile)
OUROBOROS_APP_ROOT=$HOME
OUROBOROS_REPO_DIR=$HOME/repo
OUROBOROS_DATA_DIR=$HOME/data
OUROBOROS_FILE_BROWSER_DEFAULT=$HOME/workspace

# Browser tools profile
# 0 = lean/default
# 1 = browser tooling enabled by operator helper
OUROBOROS_BROWSER_TOOLS_ENABLED=0

# Provider keys can be configured in Dashboard Settings
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
