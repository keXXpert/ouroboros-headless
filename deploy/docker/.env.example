# Ouroboros Headless VPS environment template
# Copy to /etc/ouroboros-headless/.env

# ----- VPS deploy controls (host-side) -----
# 0 = lean VPS image (default, no Playwright Chromium)
# 1 = include browser tooling in image build
VPS_ENABLE_BROWSER_TOOLS=0

# ----- Telegram bridge (optional fallback; recommended to configure in Dashboard) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Server bind/security -----
# Host-side bind for published Docker port
OUROBOROS_HOST_BIND=127.0.0.1
OUROBOROS_SERVER_PORT=8765
OUROBOROS_NETWORK_PASSWORD=

# Required for Docker/non-localhost safety contract.
# This path must exist in container runtime (see compose volume mappings).
OUROBOROS_FILE_BROWSER_DEFAULT=/var/lib/ouroboros-headless/workspace

# Container runtime paths are set by compose (`OUROBOROS_REPO_DIR=/app`,
# `OUROBOROS_DATA_DIR=/var/lib/ouroboros-headless/data`) and intentionally
# omitted from this host env file to avoid operator confusion.

# Host-side build context path (used by docker-compose.vps.yml build.context).
# Override only if the repo is checked out to a non-standard location.
# OUROBOROS_REPO_DIR_HOST=/opt/ouroboros-headless

# Provider API keys are recommended via Dashboard Settings.
# Optional fallback via env:
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
